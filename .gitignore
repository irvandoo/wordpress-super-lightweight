# WordPress Super Lightweight - Git Ignore File

# ============================================================================
# DOCUMENTATION & INTERNAL FILES (DO NOT PUSH)
# ============================================================================
docs/
.kiro/

# ============================================================================
# WORDPRESS CONFIGURATION (SENSITIVE)
# ============================================================================
wp-config.php
wp-config-local.php

# ============================================================================
# WORDPRESS CORE (OPTIONAL - UNCOMMENT IF NEEDED)
# ============================================================================
# Uncomment these if you want to exclude WordPress core files
# and only track your customizations
# /wp-admin/
# /wp-includes/
# /index.php
# /license.txt
# /readme.html
# /wp-*.php
# /xmlrpc.php

# ============================================================================
# UPLOADS & MEDIA
# ============================================================================
wp-content/uploads/
wp-content/upgrade/
wp-content/backup-db/
wp-content/backups/
wp-content/blogs.dir/
wp-content/cache/

# ============================================================================
# PLUGINS & THEMES (OPTIONAL)
# ============================================================================
# Uncomment to exclude all plugins/themes and only track specific ones
# wp-content/plugins/*
# !wp-content/plugins/.gitkeep
# wp-content/themes/*
# !wp-content/themes/.gitkeep

# Keep mu-plugins (our optimizations)
!wp-content/mu-plugins/

# ============================================================================
# WORDPRESS GENERATED FILES
# ============================================================================
.htaccess
sitemap.xml
sitemap.xml.gz
wp-sitemap.xml

# ============================================================================
# LOGS & DEBUGGING
# ============================================================================
*.log
error_log
debug.log
wp-content/debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# OPERATING SYSTEM FILES
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# PhpStorm / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================================================
# PACKAGE MANAGERS
# ============================================================================

# Node.js
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Composer
/vendor/
composer.lock

# ============================================================================
# BUILD & TEMPORARY FILES
# ============================================================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~.nib
*.sass-cache
*.css.map
*.js.map

# ============================================================================
# SECURITY & SENSITIVE DATA
# ============================================================================
*.pem
*.key
*.cert
*.crt
.env
.env.local
.env.*.local
secrets.json

# ============================================================================
# BACKUP FILES
# ============================================================================
*.sql
*.sql.gz
*.sql.zip
*.tar.gz
*.zip
backup/
backups/

# ============================================================================
# WORDPRESS SPECIFIC
# ============================================================================

# Advanced Custom Fields (ACF) Pro
wp-content/plugins/advanced-custom-fields-pro/

# WP Rocket (caching plugin)
wp-content/wp-rocket-config/
wp-content/cache/wp-rocket/

# W3 Total Cache
wp-content/w3tc-config/
wp-content/cache/tmp/
wp-content/cache/minify/

# WP Super Cache
wp-content/cache/supercache/

# Object Cache
wp-content/object-cache.php

# Maintenance mode
.maintenance

# ============================================================================
# CUSTOM EXCLUSIONS
# ============================================================================

# Add your custom exclusions below
# Example:
# my-custom-file.php
# my-custom-folder/
